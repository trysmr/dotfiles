{
  "respectGitignore": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(terraform fmt:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ls:*)",
      "Bash(*bundle list*)",
      "Bash(*rails test*)",
      "Bash(*rails spec*)",
      "Bash(*rubocop*)",
      "Bash(*rspec*)",
      "Bash(*brakeman*)",
      "Read(~/.zshrc)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(CLAUDE.md)",
      "Read(.claude/CLAUDE.md)",
      "Read(README.md)",
      "Read(doc/**/*.md)",
      "Read(docs/**/*.md)",
      "Skill(codex-review)",
      "Skill(commit)",
      "Skill(create-branch)",
      "Skill(deep-review)",
      "Skill(drawio)",
      "Skill(plan-feature)",
      "Skill(pr)",
      "Skill(pr-release)",
      "Skill(reload-context)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:blog.rubygems.org)",
      "WebFetch(domain:bundler.io)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:edgeguides.rubyonrails.org)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:packages.debian.org)",
      "WebFetch(domain:railsdiff.org)",
      "WebFetch(domain:rubygems.org)",
      "WebFetch(domain:auth.openai.com)",
      "mcp__chrome-devtools"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)",
      "Bash(rm --recursive:*)",
      "Bash(*sh -c*)",
      "Bash(eval:*)",
      "Bash(source:*)",
      "Bash(exec:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git -C:*)",
      "Bash(git --git-dir:*)",
      "Bash(git --work-tree:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git push *--force*)",
      "Bash(git push -f:*)",
      "Bash(git push --delete:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Bash(truncate:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(mkfs:*)",
      "Bash(*rails credentials:diff*)",
      "Bash(*rails credentials:edit*)",
      "Bash(*rails credentials:show*)",
      "Read(.env.*)",
      "Write(.env*)",
      "Read(node_modules)",
      "Read(node_modules/**)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(chmod:*)",
      "Bash(git stash:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr reopen:*)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load_context.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/docker_rails_exec_check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/bash_safety_check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/write_safety_check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/json_validate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/doc_freshness_check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/contract_check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/render_mermaid.sh",
            "timeout": 30,
            "statusMessage": "Mermaidダイアグラムをレンダリング中..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load_context.sh --force"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "outputStyle": "Explanatory",
  "language": "japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "blog.rubygems.org",
        "bundler.io",
        "claude.com",
        "code.claude.com",
        "docs.anthropic.com",
        "edgeguides.rubyonrails.org",
        "hub.docker.com",
        "packages.debian.org",
        "railsdiff.org",
        "rubygems.org"
      ],
      "allowUnixSockets": [
        "~/.docker/run/docker.sock"
      ]
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "verbose": true,
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
