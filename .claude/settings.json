{
  "respectGitignore": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(gh pr *:*)",
      "Bash(docker compose exec app bundle list:*)",
      "Bash(docker compose exec app rails test:*)",
      "Bash(docker compose exec app bin/rails test:*)",
      "Bash(docker compose exec app bin/rails spec:*)",
      "Bash(docker compose exec app bundle exec rspec:*)",
      "Bash(docker compose exec app bundle exec rubocop:*)",
      "Bash(docker compose exec app bin/rubocop:*)",
      "Bash(docker compose exec app bin/brakeman)",
      "Bash(docker compose exec app rspec:*)",
      "Read(~/.zshrc)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(CLAUDE.md)",
      "Read(.claude/CLAUDE.md)",
      "Read(README.md)",
      "Read(**/*.md)",
      "Skill(reload-context)",
      "Skill(create-branch)",
      "Skill(recent-changes-review)",
      "Skill(commit)",
      "Skill(pr)",
      "Skill(code-search)",
      "Skill(plan-feature)",
      "Skill(codex-review)",
      "Skill(review)",
      "Skill(record-lesson)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -R:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)",
      "Bash(rm --recursive:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(zsh -c:*)",
      "Bash(eval:*)",
      "Bash(source:*)",
      "Bash(exec:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git -C:*)",
      "Bash(git --git-dir:*)",
      "Bash(git --work-tree:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --delete:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Bash(truncate:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(mkfs:*)",
      "Read(.env.*)",
      "Write(.env*)",
      "Read(node_modules)",
      "Read(node_modules/**)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(chmod:*)",
      "Bash(git stash:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load_context.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/docker_rails_exec_check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/bash_safety_check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/write_safety_check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/json_validate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/doc_freshness_check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/render_mermaid.sh",
            "timeout": 30,
            "statusMessage": "Mermaidダイアグラムをレンダリング中..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load_context.sh --force"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "japanese",
  "autoMemoryEnabled": true
}
