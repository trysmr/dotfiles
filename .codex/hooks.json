{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/load_context.sh\"",
            "timeout": 10,
            "statusMessage": "Loading Codex workspace context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/command_safety_check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking shell command safety"
          },
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/docker_rails_exec_check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking Rails command environment"
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/hooks/japanese_commit_check.py\"",
            "timeout": 10,
            "statusMessage": "Checking Japanese commit text"
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/write_safety_check.sh\"",
            "timeout": 5,
            "statusMessage": "Checking write target safety"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/command_safety_check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking approval request safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/json_validate.sh\"",
            "timeout": 5,
            "statusMessage": "Validating JSON changes"
          },
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/doc_freshness_check.sh\"",
            "timeout": 5,
            "statusMessage": "Checking documentation freshness"
          },
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/contract_check.sh\"",
            "timeout": 5,
            "statusMessage": "Checking local contracts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$HOME/.codex/hooks/render_mermaid.sh\"",
            "timeout": 30,
            "statusMessage": "Rendering Mermaid diagrams"
          }
        ]
      }
    ]
  }
}
